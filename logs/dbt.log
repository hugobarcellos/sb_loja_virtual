         ,a.dt_prevista_compra
         ,a.cd_fornecedor
         ,a.ds_status_compra
         ,b.cd_categoria_financeira
         ,b.ds_observacoes
         ,b.cd_produto_bling
         ,b.ds_unidade
         ,b.qt_item
         ,b.vl_item
         ,b.qt_item * b.vl_item as vl_total_item
         ,a.vl_total_compra
     from cte_compra        as a
left join cte_item_compra   as b
       on a.cd_codigo_interno = b.cd_codigo_interno
)

, cte_produto as (
