         ,a.cd_categoria_financeira
         ,a.ds_observacoes
         ,a.cd_produto_bling
         ,a.cd_produto
         ,a.nm_produto_completo
         ,a.ds_unidade
         ,a.qt_item
         ,a.vl_item
        --  ,b.qt_item
        --  ,b.vl_item
     from cte_item          as a
