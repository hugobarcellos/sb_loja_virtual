        ,cd_produto_bling
        ,cd_produto
        ,nm_produto
        ,nm_produto_completo
        ,ds_subcategoria
        ,ds_categoria	
        ,ds_classificacao_produto	
        ,ds_origem_produto	
        ,qt_item	
        ,vl_item	
        ,vl_total_item
        ,vl_desconto_rateio	
        ,vl_frete_rateio
        ,vl_total_pedido	
        ,vl_custo_item
        ,vl_custo_pedido
        ,nm_forma_pagamento
        ,cd_contato
        ,nm_contato
        ,nr_doc_contato
        ,nm_loja
        ,ds_tipo_loja
    from `igneous-sandbox-381622`.`dbt_dw_az`.`tb_pedido`
)

, cte_base as (
