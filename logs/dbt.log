with cte_header as (
  select id
        ,contato__id
        ,forma_pagamento__id
        ,situacao
        ,valor
        ,vencimento
    from `igneous-sandbox-381622`.`datalake_bling`.`contas_pagar`
)

, cte_item as (
  select id
        ,data_emissao
        ,competencia
        ,historico
        ,categoria__id
        ,forma_pagamento__id
        ,ocorrencia__tipo
        ,portador__id
        ,saldo
        ,situacao
        ,valor
        ,vencimento
    from `igneous-sandbox-381622`.`datalake_bling`.`contas_pagar_detalhes`
)

, cte_categoria_financeira as (
  select distinct
         id
        ,descricao
