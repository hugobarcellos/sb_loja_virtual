        ,qt_item	
        ,vl_item	
        ,vl_total_item
        ,vl_desconto_rateio	
        ,vl_frete_rateio
        ,vl_total_pedido	
        ,vl_custo_item
        ,vl_custo_pedido
        ,ds_forma_pagamento
        ,cd_contato
        ,nm_contato
        ,nr_doc_contato
