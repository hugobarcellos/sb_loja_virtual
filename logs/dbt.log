        ,ds_endereco_municipio
    from `igneous-sandbox-381622`.`dbt_dw_stg`.`stg_contatos`
   where ds_tipo_contato = 'Cliente'
)

, cte_pedido as (
  select cd_codigo_interno
        ,cd_pedido
        ,dt_prim_dia_mes	
        ,dt_pedido
        ,cd_status_pedido
        ,ds_status_pedido
        ,cd_produto_bling
        ,cd_produto
        ,nm_produto
        ,nm_produto_completo
        ,ds_subcategoria
        ,ds_categoria	
        ,ds_classificacao_produto	
