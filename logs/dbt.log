with cte_meta as (
  select  dt_prim_dia_mes
         ,dt_data
         ,nr_dia
         ,vl_meta_dia_acumulado
         ,vl_meta_dia
         ,vl_objetivo_total
     from `igneous-sandbox-381622`.`dbt_dw_az`.`tb_objetivo_faturamento`
)

, cte_pedido as (
