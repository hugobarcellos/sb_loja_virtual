         ,json_value(i.json_item, '$.unidade')                                  as ds_unidade
         ,cast(json_value(i.json_item, '$.quantidade') as int64)                as qt_item
         ,cast(json_value(i.json_item, '$.valor') as float64)                   as vl_item
