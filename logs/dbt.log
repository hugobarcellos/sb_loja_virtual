     from `igneous-sandbox-381622`.`dbt_dw_az`.`tb_venda_produto_base`
)

, cte_base as (
    select distinct 
           a.cd_produto_bling
          ,a.cd_produto
          ,a.nm_produto
          ,a.nm_produto_completo
          ,a.ds_variacao
          ,a.cd_produto_bling_composicao
