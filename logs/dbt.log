        ,nullif(trim(categoria__id), '')             as cd_categoria_financeira
        ,nullif(trim(observacoes), '')               as ds_observacoes
        ,itens
   from `igneous-sandbox-381622`.`datalake_bling`.`pedidos_compras_detalhes`
)

