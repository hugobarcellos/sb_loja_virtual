, cte_orcamento as (
  select dt_prim_dia_mes
        ,ds_categoria_despesa
        ,vl_orcado
    from `igneous-sandbox-381622`.`dbt_dw_stg`.`stg_orcamento`
)

   select a.*
         ,coalesce(vl_orcado,0) vl_orcado
