          ,a.ds_unidade
          ,a.qt_item
          ,a.vl_item
          ,a.vl_total_item
          ,a.ds_tipo_produto
          ,a.ds_subcategoria
          ,a.ds_categoria
          ,a.ds_classificacao_produto
          ,a.ds_origem_produto
          ,a.fg_produto_composicao
          ,b.lk_produto_compra
     from cte_base         as a
left join cte_link_produto as b
       on a.cd_codigo_interno = b.cd_codigo_interno
      and a.cd_produto = b.cd_produto
left join cte_fornecedor   as c
