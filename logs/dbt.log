          ,a.qt_dias_mes_anterior
          ,a.qt_dias_tres_meses

)

, cte_cobertura_atual as (
    select a.cd_produto_bling
          ,a.cd_produto
          ,a.cd_codigo_barras
          ,a.nm_produto
          ,a.nm_produto_completo
