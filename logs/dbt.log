        ,ds_forma_pagamento
        ,cd_contato
        ,nm_contato
        ,nr_doc_contato
        ,nm_loja
        ,ds_tipo_loja
    from `igneous-sandbox-381622`.`dbt_dw_az`.`tb_pedido`
)

, cte_base as (
