     and ds_status_pedido not in ('CANCELADO')
group by dt_pedido
)

   select a.dt_prim_dia_mes
         ,a.dt_data
         ,b.vl_total_pedido
         ,b.vl_frete
         ,b.vl_taxa
         ,b.vl_custo_total_pedido
         ,a.vl_meta_dia_acumulado
         ,a.vl_meta_dia
         ,a.vl_objetivo_total
     from cte_meta   as a
