         ,sum(vl_total_pedido) -(sum(vl_frete_rateio) + (sum(vl_total_pedido) * 0.05))                            as vl_faturamento_liquido
         ,sum(vl_custo_pedido)                                                                                    as vl_custo_merc_vendida
