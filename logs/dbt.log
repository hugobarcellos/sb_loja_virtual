          ,a.qt_pecas_sessenta_dias
          ,a.qt_dias_mes_atual
          ,a.qt_dias_mes_anterior
          ,a.qt_dias_tres_meses
          ,a.dt_ultima_atualizacao
      from cte_joins               as a  
)

, cte_cobertura_total as (
    select a.cd_produto_bling
