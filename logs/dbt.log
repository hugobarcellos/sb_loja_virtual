          ,a.ds_categoria
          ,a.ds_classificacao_produto
          ,a.ds_origem_produto
          ,a.nm_fornecedor
          ,a.lk_ultima_compra
          ,a.ds_tipo_estoque
          ,a.qt_lead_time
          ,a.qt_cobertura_desejada
          ,a.qt_estoque_minimo
          ,a.qt_estoque_atual
          ,a.vl_custo_cadastro
